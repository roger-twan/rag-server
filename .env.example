ENVIRONMENT=development
DATABASE_URL=postgresql://rag:rag@localhost:5432/rag_server_db
GITHUB_TOKEN=.           # GitHub personal access token
GITHUB_HTTP_TIMEOUT_SECONDS=30
GITHUB_HTTP_RETRIES=3
GOOGLE_API_KEY=.         # For Google Gemini Answers
PINECONE_API_KEY=.       # For Pinecone vector database
PINECONE_INDEX_HOST=.    # For Pinecone vector database
ENABLE_SPARSE_SEARCH=false
OPENAI_API_KEY=.         # For text-embedding-3-small
COHERE_API_KEY=.         # For reranking
DEEPSEEK_API_KEY=.       # For DeepSeek LLM
GITHUB_WEBHOOK_SECRET=.  # For HMAC verification
PUBLIC_API_TOKEN=.       # Token for public /query API access
ADMIN_API_TOKEN=.        # Token for admin ingestion APIs
LLM_PROVIDER=google      # "google", "openai", or "deepseek"

# Optional LangSmith tracing
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=.
LANGSMITH_PROJECT=rag-server
LANGSMITH_ENDPOINT=
LANGSMITH_WORKSPACE_ID=
LANGCHAIN_CALLBACKS_BACKGROUND=

# Optional RAGAS evaluator settings
RAGAS_LLM_MODEL=gpt-4o-mini
RAGAS_EMBEDDING_MODEL=text-embedding-3-small
